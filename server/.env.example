# ops-hub server environment — copy to .env and fill in values.
#
# Two-tier config: the variables below are read at server startup. Anything
# that can be changed at runtime (API keys, integration paths, alert
# thresholds, embedded URLs) lives in hub_settings.json under the data dir
# and is edited in the web UI at /workbench/settings. Empty values in
# hub_settings.json fall through to the matching OPSHUB_* env var here.
#
# ┌────────────────────────────────────────────────────────────────┐
# │ See docs/CONFIG.md for the full configuration layer diagram.   │
# └────────────────────────────────────────────────────────────────┘

# --- Required: networking & auth ---

# Listen address. Keep 127.0.0.1 in production — nginx reverse-proxies to us.
OPSHUB_HOST=127.0.0.1
OPSHUB_PORT=8001

# Dev mode: allows CORS from Vite dev server + disables Secure cookie flag.
OPSHUB_DEV=0

# Session signing key. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OPSHUB_SECRET=CHANGE_ME_GENERATE_A_RANDOM_32_BYTE_VALUE

# Admin account (single-user). Username is arbitrary.
OPSHUB_USER=admin

# bcrypt hash of your password. Generate with:
#   cd server && python -m app.core.hashpw
OPSHUB_PASSWORD_HASH=

# CSRF allow-list: comma-separated origins permitted to make state-changing
# /api/* calls. Requests with a missing or non-matching Origin get 403.
# Required in production; dev mode auto-adds the Vite dev server origins.
OPSHUB_ALLOWED_ORIGINS=https://ops.example.com

# Session cookie domain. Empty = host-only (safest). Set to e.g. ".example.com"
# only if you want to share the session across sub-domains.
OPSHUB_COOKIE_DOMAIN=

# Where to store app data (sqlite, uploads, hub_settings.json).
# OPSHUB_DATA_DIR=/var/lib/ops-hub

# --- Optional: terminal auto-capture ---

# Periodically snapshot the active tmux pane into terminal_history.sqlite3
# OPSHUB_TERMINAL_AUTOCAPTURE=1
# OPSHUB_TERMINAL_AUTOCAPTURE_INTERVAL=300

# --- Optional: AI / market integrations (also editable in UI) ---
#
# These are the fallbacks used when hub_settings.json doesn't have the key.
# Prefer editing them in 系统配置 → 各 section. Only set here if you want
# values to survive a hub_settings.json wipe.

# APIMART_KEY=
# SORFTIME_KEY=
# OPENAI_API_KEY=
# OPSHUB_GBRAIN_BIN=/usr/local/bin/gbrain
# OPSHUB_BRAIN_ROOT=/var/lib/ops-hub/brain

# --- Optional: CPU-alert delivery (also editable in UI) ---
#
# Feishu / Lark notifications when ops-hub's own CPU stays above threshold.
# Driven by scripts/cpu_alert.py via /etc/cron.d/.
#
# OPSHUB_ALERT_WEBHOOK=           # Custom-bot webhook URL
# OPSHUB_ALERT_APP_ID=            # Self-built Feishu app id (alt channel)
# OPSHUB_ALERT_APP_SECRET=
# OPSHUB_ALERT_CHAT_ID=           # Target open_chat_id (oc_xxx...)
# OPSHUB_ALERT_THRESHOLD=80       # CPU% trigger
# OPSHUB_ALERT_SUSTAIN=5          # Minutes above threshold before firing
# OPSHUB_ALERT_COOLDOWN=30        # Minutes between alerts

# --- Optional: external integration paths (also editable in UI) ---
#
# ops-hub works standalone without any of these. Set them only if you've
# installed the corresponding tool and want the monitor / agent picker to
# light up against it. Examples in comments are common locations.

# OPSHUB_HERMES_BIN=/usr/local/bin/hermes
# OPSHUB_CODEX_BIN=
# OPSHUB_CLAUDE_BIN=
# OPSHUB_KIRO_CLI_BIN=
# OPSHUB_HERMES_DB=
# OPSHUB_CODEX_DB=
# OPSHUB_FEISHU_CODEX_DB=
# OPSHUB_KIRO_GATEWAY_DB=
# OPSHUB_KIRO_CLI_DB=
# OPSHUB_KIRO_CLI_SESSIONS_DIR=
# OPSHUB_CLAUDE_PROJECTS_DIR=
# OPSHUB_HERMES_NODE_BIN=
# OPSHUB_BUN_BIN=
